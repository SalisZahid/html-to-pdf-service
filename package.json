{
  "name": "datarover-backend",
  "version": "1.0.0",
  "description": "Production-ready Node.js backend with scalable modular architecture (Express, MongoDB, JWT).",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "node -e \"console.log('Skipping standard build')\"",
    "postinstall": "PUPPETEER_CACHE_DIR=/tmp/puppeteer node node_modules/puppeteer/install.mjs",
    "start": "node src/server.js",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "node",
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "backend",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "puppeteer": "^24.40.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.4.2"
  }
}
